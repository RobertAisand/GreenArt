{
    "trailingComma": "none",
    "tabWidth": 4,
    "useTabs": true,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "arrowParens": "avoid",
    "importOrder": [
            "<THIRD_PARTY_MODULES>",
            "api/(.*)$",
            "app/(.*)$",
            "components/(.*)$",
            "config/(.*)$",
            "constants/(.*)$",
            "hooks/(.*)$",
            "services/(.*)$",
            "shared/(.*)$",
            "stores/(.*)$",
            "utils/(.*)$",
            "^../(.*)$",
            "^./(.*)$",
            "(.scss)$"
        ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true,
    "plugins": ["@trivago/prettier-plugin-sort-imports"]
}
